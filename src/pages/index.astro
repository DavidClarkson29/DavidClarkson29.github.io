---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cards from "../components/Cards.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {pageTag, pageDescription,homeTdk} from '../data/content';
---

<BaseLayout
title={homeTdk.title  || ''}
description ={homeTdk.description  || ''}
keywords = {homeTdk.keywords  || ''}
>
	<div class="section hero">
		<div class="container">
			<SectionHeader
				tag={pageTag.index}
				description={pageDescription.index}>
					<h1 class="font-special text-5xl font-bold tracking-widest uppercase">王百川</h1>
			</SectionHeader>
			<Cards />
		</div>
	</div>

</BaseLayout>



