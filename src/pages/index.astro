---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cards from "../components/Cards.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {pageTag, pageDescription,homeTdk} from '../data/content';
---

<BaseLayout
title={homeTdk.title  || ''}
description ={homeTdk.description  || ''}
keywords = {homeTdk.keywords  || ''}
>
	<div class="section hero">
		<div class="container">
			<SectionHeader
				tag={pageTag.index}
				description={pageDescription.index}>
			</SectionHeader>
			<Cards />
		</div>
	</div>

</BaseLayout>

<style is:global>
  /* 强制卡片单列全宽显示，解决溢出 */
  .project-list {
    display: flex !important;
    flex-direction: column !important;
    gap: 4rem !important; /* 增加上下间距，更具呼吸感 */
    width: 100% !important;
  }

  .project-card {
    width: 100% !important;
    display: block !important;
    position: relative !important;
  }

  /* 修复文字容器 */
  .project-info {
    position: static !important;
    width: 100% !important;
    padding-top: 1.5rem !important;
  }

  .project-info h3, 
  .project-info p {
    white-space: normal !important; /* 允许换行 */
    word-break: break-word !important; /* 强制长词断行 */
    overflow: visible !important;
    display: block !important;
  }
</style>

