---
import BaseLayout from '../../layouts/BaseLayout.astro';
// 这里假设你有 5 张 PPT 图片，如果有更多，手动增加数组数字即可
const pptPages = [1, 2, 3, 4, 5, 6, 7]; 
---

<BaseLayout title="Keyboard Design | Baichuan Wang">
    <div class="project-detail-container" style="max-width: 1000px; margin: 0 auto; padding: 6rem 1rem;">
        <header style="margin-bottom: 4rem; text-align: center;">
            <h1 style="font-size: 2.5rem; letter-spacing: 2px; text-transform: uppercase;">Keyboard Design</h1>
            <p style="color: var(--color-300); margin-top: 1rem;">Industrial Design / Strategy / CMF</p>
        </header>

        <div class="ppt-images">
            {pptPages.map((num) => (
                <img 
                    src={`/assets/projects/keyboard/${num}.jpg`} 
                    alt={`Page ${num}`}
                    style="width: 100%; display: block; margin-bottom: 0.5rem; border-radius: 4px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);"
                />
            ))}
        </div>

        <footer style="margin-top: 6rem; text-align: center;">
            <a href="/" style="text-decoration: none; color: var(--color-100); border: 1px solid; padding: 0.8rem 2rem; border-radius: 30px;">Back to Home</a>
        </footer>
    </div>
</BaseLayout>
