---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Optimized for lightning-fast inspiration capture.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 3rem;">
					<div>
						<h3 style="margin-bottom: 1rem;">Design Concept</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							灵沐 (LingMu) 旨在探索<strong>“无阻碍记录”</strong>。通过极简输入逻辑，将碎片思绪转化为结构化笔记。
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 1rem;">Tech Stack</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							本项目采用 <strong>Vite + React + Tailwind CSS</strong> 构建，并通过 Vercel 自动化部署，实现了从设计原型到生产级代码的高速转化。
						</p>
					</div>
				</div>
				
				<div class="pure-embed-viewport">
					<div class="pure-embed-lock">
						<iframe 
							src="https://lingmu-app.vercel.app" 
							style="border: none; width: 100%; height: 100%;" 
							allowfullscreen>
						</iframe>
					</div>
				</div>

				<p style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--color-500); font-style: italic;">
					💡 提示：本窗口已锁定 9:30 手机比例，底部导航栏将 100% 露出来。
				</p>
			</div>
		</section>
		
		<div style="height: 100px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	/* 1. 外层视口：负责上下间距和背景衬托 */
	.pure-embed-viewport {
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 3rem 0;
		background: #0d0d0d; /* 给一个几乎纯黑的背景，衬托 App */
		border-radius: 20px;
	}

	/* 2. 核心修复：锁定比例的 App 容器 */
	.pure-embed-lock {
		width: 100%;
		max-width: 420px; /* 电脑端限制最大手机宽度，防止挤压 */
		aspect-ratio: 20 / 30; /* 核心：锁定为非常长的 9:30 比例，强制把底部栏推出来 */
		background: #000;
		display: block;
		position: relative;
		overflow: hidden;
		/* 彻底去掉边框和模拟器小条，无缝嵌入 */
		border: none;
		box-shadow: 0 40px 100px rgba(0,0,0,0.6);
	}

	/* 移动端适配 */
	@media (max-width: 767px) {
		.pure-embed-lock {
			max-width: 100%; /* 手机访问时占满全宽 */
			aspect-ratio: 9 / 28; /* 稍微缩短一点比例 */
		}
	}
</style>
