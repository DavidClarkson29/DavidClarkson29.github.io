---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Sidebar navigation optimized for universal viewing.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
					<div>
						<h3 style="margin-bottom: 0.5rem;">Strategic Shift</h3>
						<p style="line-height: 1.6; color: var(--color-200);">
							为了优化在大屏端的交互体验，我们将导航栏移至左侧浮动区域。为了确保不同终端的体验一致性，我们引入了<strong>媒体查询（Media Queries）自适应策略</strong>。
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 0.5rem;">Deployment</h3>
						<p style="line-height: 1.6; color: var(--color-200);">
							原型通过 <strong>Vercel Edge Runtime</strong> 实时运行。左侧导航栏采用高斯模糊材质，确保在任何背景下都能保持清晰的层级关系。
						</p>
					</div>
				</div>
				
				<div class="demo-viewport">
					<div class="secure-app-frame">
						<div class="browser-bar">
							<div class="dots"><span></span><span></span><span></span></div>
							<span class="url">lingmu-app.vercel.app</span>
						</div>
						<div class="iframe-box">
							<iframe 
								src="https://lingmu-app.vercel.app" 
								style="border: none; width: 100%; height: 100%; background: #000;" 
								allowfullscreen>
							</iframe>
						</div>
					</div>
				</div>

				<p style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: var(--color-500); font-style: italic;">
					💡 提示：本窗口已锁定 3:4 比例，可直接在左侧点击或内部滑动交互。
				</p>
			</div>
		</section>
		
		<div style="height: 100px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	/* =========================================================
	   💻 PC 端（大屏幕）样式 - 保持沉浸式体验
	   ========================================================= */
	
	/* 外层视口：强制留白 (Padding)，绝不顶格 */
	.demo-viewport {
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 40px 0; /* PC端上下强制留出 40px 的安全呼吸间距 */
		background: #0f0f0f; /* 给外层一个深色背景，衬托 App */
		border-radius: 20px;
	}

	/* 容器：限制最大宽度，防止巨大化 */
	.secure-app-frame {
		width: 100%;
		max-width: 900px; /* 限制电脑端最大宽度 */
		background: #000;
		border-radius: 24px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid var(--border);
		box-shadow: 0 40px 100px rgba(0,0,0,0.6);
	}

	/* 模拟系统顶部小条 */
	.browser-bar {
		height: 40px;
		background: #1a1a1b;
		display: flex;
		align-items: center;
		padding: 0 16px;
		border-bottom: 1px solid #333;
		gap: 12px;
	}

	.dots { display: flex; gap: 6px; }
	.dots span { width: 8px; height: 8px; border-radius: 50%; background: #333; }
	.url { font-size: 10px; color: #666; font-family: monospace; }

	/* Iframe 承载区：填满剩余空间 */
	.iframe-box {
		flex: 1;
		width: 100%;
		background: #fff; /* iframe 加载前的白底 */
	}

	/* =========================================================
	   📱 手机端（小屏幕）样式 - 精准修复遮挡问题
	   ========================================================= */
	
	/* 仅针对最大宽度为 767px 的设备（即手机纵向模式）应用此样式 */
	@media (max-width: 767px) {
		.demo-viewport {
			padding: 0; /* 手机端删除上下留白，将 App 顶格，腾出垂直空间 */
			border-radius: 12px;
		}
		
		.secure-app-frame {
			max-width: 100%; /* 手机访问时占满全宽 */
			border-radius: 16px;
			
			/* 💡 核心修复：锁死为扁长方形比例 (e.g., 3:4 or 4:3)
			   这能防止在移动端生成一个“巨高”的容器。内容会在容器内流动，
			   确保底部的导航栏和内容绝不会再被裁切。 */
			aspect-ratio: 4 / 3; /* 推荐：扁长方形，给底部留余白 */
		}
	}
</style>
