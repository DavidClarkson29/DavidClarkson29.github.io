---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Optimized for lightning-fast inspiration capture.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 3rem;">
					<div>
						<h3 style="margin-bottom: 1rem;">Design Concept</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							灵沐 (LingMu) 是一款基于 AI 辅助设计的原型，旨在探索<strong>“无阻碍记录”</strong>。通过极简的输入逻辑，将用户的碎片化思绪瞬间转化为结构化笔记。
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 1rem;">Tech Stack</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							本项目采用 <strong>Vite + React + Tailwind CSS</strong> 构建，并通过 Vercel 自动化部署，实现了从设计原型到生产级代码的高速转化。
						</p>
					</div>
				</div>
				
				<div class="fullscreen-demo-wrapper">
					<div class="demo-window">
						<div class="window-header">
							<div class="dot-group">
								<span class="dot"></span>
								<span class="dot"></span>
								<span class="dot"></span>
							</div>
							<span class="window-title">Live Prototype - https://lingmu-app.vercel.app</span>
						</div>
						<div class="iframe-container">
							<iframe 
								src="https://lingmu-app.vercel.app" 
								style="border: none; width: 100%; height: 100%;" 
								allowfullscreen>
							</iframe>
						</div>
					</div>
					<p class="demo-hint" style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--color-500); font-style: italic;">
						💡 本窗口为实时运行的 App 实例，可直接点击进行交互体验。
					</p>
				</div>
			</div>
		</section>
		
		<div style="height: 100px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	.fullscreen-demo-wrapper {
		width: 100%;
		margin: 2rem 0;
	}

	/* 模拟一个高级的浏览器/系统窗口，而不是手机壳 */
	.demo-window {
		width: 100%;
		height: 85vh; /* 占据屏幕 85% 的高度 */
		min-height: 700px;
		background: #000;
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid var(--border);
		box-shadow: 0 30px 60px rgba(0,0,0,0.4);
	}

	.window-header {
		height: 40px;
		background: #1a1a1b;
		display: flex;
		align-items: center;
		padding: 0 16px;
		border-bottom: 1px solid #333;
		gap: 16px;
	}

	.dot-group {
		display: flex;
		gap: 8px;
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #444;
	}

	.window-title {
		font-size: 12px;
		color: #888;
		font-family: monospace;
	}

	.iframe-container {
		flex: 1;
		width: 100%;
		height: 100%;
		background: #fff;
	}

	@media (max-width: 767px) {
		.demo-window {
			height: 75vh;
			min-height: 500px;
		}
		.window-title {
			display: none; /* 手机端隐藏长链接标题 */
		}
	}
</style>
