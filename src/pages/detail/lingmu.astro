---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Optimized for lightning-fast inspiration capture.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 3rem;">
					<div>
						<h3 style="margin-bottom: 0.8rem;">Design Concept</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							灵沐 (LingMu) 旨在探索<strong>“无阻碍记录”</strong>。通过极简输入逻辑，将碎片思绪转化为结构化笔记。
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 0.8rem;">Tech Stack</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							由 <strong>Vite + React</strong> 构建并部署于 Vercel，确保了 100% 的真实交互还原。
						</p>
					</div>
				</div>
				
				<div class="pure-embed-container">
					<iframe 
						src="https://lingmu-app.vercel.app" 
						class="full-height-iframe"
						allowfullscreen>
					</iframe>
				</div>

				<p style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--color-500); font-style: italic;">
					💡 提示：以上为实时交互原型，可直接操作。
				</p>
			</div>
		</section>
		
		<div style="height: 100px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	/* 1. 容器：彻底去掉背景和边框，居中显示 */
	.pure-embed-container {
		width: 100%;
		max-width: 450px; /* 限制手机端的最大显示宽度 */
		margin: 0 auto;
		display: block;
		position: relative;
		/* 关键：利用 aspect-ratio 确保高度随宽度变化，不裁切底部 */
		aspect-ratio: 9 / 19; 
	}

	/* 2. Iframe：完全透明嵌入 */
	.full-height-iframe {
		width: 100%;
		height: 100%;
		border: none;
		display: block;
		background: transparent;
		/* 移除所有阴影和边框 */
		box-shadow: none;
	}

	/* 移动端适配：如果是手机访问，直接占满宽度 */
	@media (max-width: 767px) {
		.pure-embed-container {
			max-width: 100%;
			aspect-ratio: 9 / 18.5; /* 稍微调整移动端的比例 */
		}
	}
</style>
