---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Sidebar navigation optimized for universal viewing.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
					<div>
						<h3 style="margin-bottom: 0.5rem;">Design Concept</h3>
						<p style="line-height: 1.6; color: var(--color-200);">
							灵沐 (LingMu) explores <strong>“frictionless capture”</strong>. Through a minimal input system, fragmented thoughts are transformed into structured notes.
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 0.5rem;">Tech Stack</h3>
						<p style="line-height: 1.6; color: var(--color-200);">
							Built with <strong>Vite + React</strong> and deployed on Vercel. ensuring a fully authentic interactive experience.
						</p>
					</div>
				</div>
				
				<div class="demo-viewport">
					<div class="secure-app-frame">
						<div class="browser-bar">
							<div class="dots"><span></span><span></span><span></span></div>
							<span class="url">lingmu-app.vercel.app</span>
						</div>
						<div class="iframe-box">
							<iframe 
								src="https://lingmu-app.vercel.app" 
								style="border: none; width: 100%; height: 100%; background: #000;" 
								allowfullscreen>
							</iframe>
						</div>
					</div>
				</div>

				<p style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: var(--color-500); font-style: italic;">
					💡This feature is not yet optimized for mobile. Stay tuned.
				</p>
			</div>
		</section>
		
		<div style="height: 100px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	/* 1. 外层视口：负责强制上下留白 (Padding)，绝不顶格 */
	.demo-viewport {
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 40px 0; /* 核心：上下强制留出 40px 的安全呼吸间距 */
		background: #0f0f0f; /* 给外层一个深色背景，衬托 App */
		border-radius: 20px;
	}

	/* 2. 核心：锁定比例的 App 容器 */
	.secure-app-frame {
		width: 100%;
		max-width: 900px; /* 限制电脑端最大宽度，防止变得巨大 */
		/* 核心修复：锁定为 3:4 比例。高度随宽度自动计算，确保内容完全展示 */
		aspect-ratio: 3 / 4; 
		background: #000;
		border-radius: 24px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid var(--border);
		box-shadow: 0 40px 100px rgba(0,0,0,0.6);
	}

	/* 3. 模拟系统顶部小条 */
	.browser-bar {
		height: 40px;
		background: #1a1a1b;
		display: flex;
		align-items: center;
		padding: 0 16px;
		border-bottom: 1px solid #333;
		gap: 12px;
	}

	.dots { display: flex; gap: 6px; }
	.dots span { width: 8px; height: 8px; border-radius: 50%; background: #333; }
	.url { font-size: 10px; color: #666; font-family: monospace; }

	/* 4. Iframe 承载区：填满剩余空间 */
	.iframe-box {
		flex: 1;
		width: 100%;
		background: #fff; /* iframe 加载前的白底 */
	}

	/* 适配小屏幕 */
	@media (max-width: 767px) {
		.demo-viewport {
			padding: 20px 0; /* 手机端上下留白缩减到 20px，但依然保留安全呼吸 */
			border-radius: 12px;
		}
		.secure-app-frame {
			border-radius: 16px;
			max-width: 100%; /* 手机访问时占满全宽 */
			aspect-ratio: 3 / 4; /* 手机端依然锁定 3:4 */
		}
	}
</style>
