---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<BaseLayout title="LingMu UI/UX Prototype | Strategic Design">
	<main class="post-wrapper project-detail">
		<SectionHeader 
			tag="UI/UX / STRATEGIC DESIGN" 
			description="Interactive Prototype: Optimized for lightning-fast inspiration capture.">
			<h1 class="font-special text-5xl font-bold uppercase tracking-widest" style="margin: 1rem 0;">
				LingMu (灵沐)
			</h1>
		</SectionHeader>

		<section class="border-top" style="padding-top: 3rem;">
			<div class="content">
				<div class="project-intro-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 3rem;">
					<div>
						<h3 style="margin-bottom: 1rem;">Design Concept</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							灵沐 (LingMu) 是一款基于 AI 辅助设计的原型，旨在探索<strong>“无阻碍记录”</strong>。通过极简的输入逻辑，将用户的碎片化思绪瞬间转化为结构化笔记。
						</p>
					</div>
					<div>
						<h3 style="margin-bottom: 1rem;">Tech Stack</h3>
						<p style="line-height: 1.8; color: var(--color-200);">
							本项目采用 <strong>Vite + React + Tailwind CSS</strong> 构建，并通过 Vercel 自动化部署，实现了从设计原型到生产级代码的高速转化。
						</p>
					</div>
				</div>
				
				<div class="live-demo-container">
					<div class="phone-mockup">
						<div class="phone-screen">
							<iframe 
								src="https://lingmu-app.vercel.app" 
								style="border: none; width: 100%; height: 100%;" 
								allowfullscreen>
							</iframe>
						</div>
					</div>
					<p class="demo-hint" style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: var(--color-400); font-style: italic;">
						💡 这是实时运行的 App 实例，你可以直接在上方屏幕中点击操作。
					</p>
				</div>
			</div>
		</section>
		
		<div style="height: 120px;"></div>
	</main>
</BaseLayout>

<style>
	.project-detail {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--pad-inner);
	}

	.live-demo-container {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 0;
	}

	/* 模拟高质感的手机容器 */
	.phone-mockup {
		width: 100%;
		max-width: 390px; /* iPhone 15 比例 */
		height: 800px;
		background: #1a1a1b;
		border-radius: 40px;
		padding: 12px;
		border: 4px solid #333;
		box-shadow: 0 50px 100px -20px rgba(0,0,0,0.5);
		position: relative;
	}

	.phone-screen {
		width: 100%;
		height: 100%;
		background: #fff;
		border-radius: 30px;
		overflow: hidden;
		position: relative;
	}

	@media (max-width: 767px) {
		.phone-mockup {
			max-width: 320px;
			height: 650px;
			padding: 8px;
		}
	}
</style>
